  <property name="styleSheet">
   <string notr="true">QWidget {
    font-family: &quot;Segoe UI&quot;;
    font-size: 10pt;
    color: #0f172a;
}
QMainWindow, #centralwidget {
    background-color: #f3f6fb;
}
/* ===== Header ===== */
#headerFrame {
    background-color: #ffffff;
    border: 1px solid #dbe5f2;
    border-radius: 14px;
}
#logoLabel {
    background-color: #FFFFFF;
    color: #FFFFFF;
    border-radius: 28px;
    border: 1px solid #FFFFFF;
    font-size: 24px;
    font-weight: 700;
}
#appName {
    color: #0b1324;
    font-size: 21px;
    font-weight: 800;
}
#appDesc {
    color: #5b6b84;
    font-size: 10.5pt;
}
#btnLogin, #btnLogout {
    min-width: 120px;
    min-height: 38px;
    border: none;
    border-radius: 9px;
    color: #ffffff;
    font-weight: 700;
    padding: 6px 14px;
}
#btnLogin {
    background-color: #2563eb;
}
#btnLogin:hover {
    background-color: #1d4ed8;
}
#btnLogin:pressed {
    background-color: #1e40af;
}
#btnLogout {
    background-color: #ef4444;
}
#btnLogout:hover {
    background-color: #dc2626;
}
#btnLogout:pressed {
    background-color: #b91c1c;
}
/* ===== Cards Wrapper ===== */
#contentWrapper {
    background-color: transparent;
    border: none;
}
/* ===== Function Cards ===== */
#card_lichhen,
#card_pos,
#card_crm,
#card_kho,
#card_nhansu,
#card_care,
#card_baocao,
#card_hethong {
    background-color: #ffffff;
    border: 1px solid #dbe5f2;
    border-radius: 14px;
}
#card_lichhen:hover,
#card_pos:hover,
#card_crm:hover,
#card_kho:hover,
#card_nhansu:hover,
#card_care:hover,
#card_baocao:hover,
#card_hethong:hover {
    border: 1px solid #93c5fd;
    background-color: #fdfefe;
}
/* Tieu de card */
#lblTitleLichHen,
#lblTitlePOS,
#lblTitleCRM,
#lblTitleKho,
#lblTitleNhanSu,
#lblTitleCare,
#lblTitleBaoCao,
#lblTitleHeThong {
    color: #0f172a;
    font-size: 13pt;
    font-weight: 800;
}
/* Mo ta card */
#lblDescLichHen,
#lblDescPOS,
#lblDescCRM,
#lblDescKho,
#lblDescNhanSu,
#lblDescCare,
#lblDescBaoCao,
#lblDescHeThong {
    color: #596980;
    font-size: 10pt;
    line-height: 1.25em;
}
/* Nut mo chuc nang tren card */
#btn_lichhen_tiepnhan,
#btn_banhang_thanhtoan,
#btn_crm_khachhang,
#btn_kho_vattu,
#btn_nhansu_nangsuat,
#btn_customer_care,
#btn_baocao_thongke,
#btn_hethong_caidat {
    min-height: 36px;
    border: none;
    border-radius: 9px;
    background-color: #0ea5e9;
    color: #ffffff;
    font-weight: 700;
    padding: 6px 12px;
}
#btn_lichhen_tiepnhan:hover,
#btn_banhang_thanhtoan:hover,
#btn_crm_khachhang:hover,
#btn_kho_vattu:hover,
#btn_nhansu_nangsuat:hover,
#btn_customer_care:hover,
#btn_baocao_thongke:hover,
#btn_hethong_caidat:hover {
    background-color: #0284c7;
}
#btn_lichhen_tiepnhan:pressed,
#btn_banhang_thanhtoan:pressed,
#btn_crm_khachhang:pressed,
#btn_kho_vattu:pressed,
#btn_nhansu_nangsuat:pressed,
#btn_customer_care:pressed,
#btn_baocao_thongke:pressed,
#btn_hethong_caidat:pressed {
    background-color: #0369a1;
}
/* ===== Footer ===== */
#footerText {
    color: #6b7b93;
    font-size: 9.5pt;
    padding-left: 4px;
}</string>
