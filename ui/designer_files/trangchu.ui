          <string notr="true">QPushButton {
    background-color: #6c757d; /* Màu xám trung tính */
    color: white;
    border-radius: 5px;
    padding: 8px 15px;
    font-weight: bold;
}
QPushButton:hover {
    background-color: #5a6268; /* Xám đậm hơn khi lia chuột */
}</string>
