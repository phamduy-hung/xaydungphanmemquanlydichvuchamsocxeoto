    height: 12px;
}

/* Hiệu ứng khi mũi tên xổ xuống (tùy chọn) */
QComboBox::down-arrow:on {
    top: 1px; /* Đẩy mũi tên xuống 1px khi click tạo cảm giác chân thực */
}</string>
