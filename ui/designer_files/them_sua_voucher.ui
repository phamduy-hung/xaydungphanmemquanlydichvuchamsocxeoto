    color: #333333;            /* Chữ màu xám đen */
}

/* Tùy chỉnh cái nút mũi tên xổ xuống */
QComboBox::drop-down {
    border: none;
    width: 30px; /* Mở rộng chiều ngang một chút cho dễ bấm */
}

/* Chèn icon mũi tên màu đen */
/* Chèn icon mũi tên màu đen */
