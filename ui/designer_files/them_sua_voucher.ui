     <property name="styleSheet">
      <string notr="true">QComboBox {
    border: 1px solid #ced4da; /* Viền xám nhạt */
    border-radius: 5px;        /* Bo tròn 5px */
    padding: 5px 10px;         /* Khoảng cách chữ bên trong */
