          </size>
         </property>
         <property name="styleSheet">
          <string notr="true">/* Tùy chỉnh trạng thái bình thường của nút */
QPushButton {
    background-color: #007bff; /* Màu xanh dương chủ đạo */
    color: white;               /* Chữ trắng */
    border: none;               /* Không viền */
    border-radius: 5px;         /* Bo tròn góc 5px cho giống ô nhập liệu */
    padding: 5px 15px;          /* Khoảng cách chữ bên trong */
    font-weight: bold;          /* Chữ đậm cho dễ nhìn */
}

/* Hiệu ứng khi di chuột qua (Hover) */
QPushButton:hover {
    background-color: #0069d9; /* Màu xanh đậm hơn một chút */
}

/* Hiệu ứng khi nhấn giữ chuột (Pressed) */
QPushButton:pressed {
    background-color: #0056b3; /* Màu xanh đậm nhất */
    padding-left: 17px;        /* Nhích nhẹ chữ sang phải tạo cảm giác nút bị lún xuống */
    padding-top: 7px;
}</string>
