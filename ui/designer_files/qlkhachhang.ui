         <property name="styleSheet">
          <string notr="true">/* Khung của toàn bộ bảng */
QTableWidget {
    border: 1px solid #ced4da; 
    border-radius: 8px;        /* Bo tròn góc bảng 8px */
    background-color: white;
    gridline-color: #e9ecef;   /* Màu của các đường kẻ ô lưới */
    selection-background-color: #cce5ff; /* Màu nền ô khi bạn click chọn */
    selection-color: black;    /* Màu chữ khi bạn click chọn */
}

/* Tùy chỉnh Thanh tiêu đề (Tên các cột: Mã KH, Tên, SĐT...) */
QHeaderView::section {
    background-color: #f8f9fa; /* Nền xám nhạt cho thanh tiêu đề */
    border: none;
    border-bottom: 2px solid #dee2e6; /* Đường kẻ dưới của tiêu đề */
    padding: 6px;
    font-weight: bold;
    color: #495057;
}

/* Bo tròn góc trên cùng bên trái và bên phải của Thanh tiêu đề cho khớp với khung bảng */
QHeaderView::section:first {
    border-top-left-radius: 8px;
}
QHeaderView::section:last {
    border-top-right-radius: 8px;
}</string>
